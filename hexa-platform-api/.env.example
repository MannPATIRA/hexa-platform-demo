PORT=4000
# Same as frontend Vercel KV / Upstash (optional — falls back to in-memory)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# CORS: comma-separated origins allowed to call the API (browser)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SMTP (send-demo-emails)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Shipment notification emails (shipping flows)
PROCUREMENT_EMAIL=
PROCUREMENT_EMAIL_PASS=

# Microsoft Graph (procurement RFQ routes; PROCUREMENT_EMAIL is also the sending mailbox)
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_REFRESH_TOKEN=
PROCUREMENT_OVERRIDE_RECIPIENT=
